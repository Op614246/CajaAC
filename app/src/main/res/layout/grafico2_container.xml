<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/grafico2Container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guide_prod_25"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.25" />
    <TextView
        android:id="@+id/lbl_top10"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:fontFamily="@font/roboto_medium"
        android:text="Top 10 productos estrella más vendidos en mi local durante los últimos 7 días"
        android:textColor="@color/text_85"
        android:textSize="14sp"
        app:layout_constraintEnd_toStartOf="@+id/spinnerProductos"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />
    <Spinner
        android:id="@+id/spinnerProductos"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="4dp"
        android:background="@null"
        android:minWidth="120dp"
        app:layout_constraintBottom_toBottomOf="@id/lbl_top10"
        app:layout_constraintEnd_toStartOf="@+id/spinnerPeriodo"
        app:layout_constraintTop_toTopOf="@id/lbl_top10" />
    <Spinner
        android:id="@+id/spinnerPeriodo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@null"
        android:minWidth="140dp"
        app:layout_constraintBottom_toBottomOf="@id/lbl_top10"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/lbl_top10" />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/card_producto_top"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="25dp"
        android:background="@drawable/border_rounded_10"
        app:layout_constraintEnd_toStartOf="@id/guide_prod_25"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/lbl_top10">
        <TextView
            android:id="@+id/lbl_ranking" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:background="@drawable/badge_info" android:fontFamily="@font/roboto_medium" android:paddingHorizontal="12dp" android:paddingVertical="4dp" android:text="Ranking semanal" android:textColor="@color/white" android:textSize="10sp" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" />
        <TextView
            android:id="@+id/lbl_number1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginStart="16dp" android:layout_marginTop="8dp" android:fontFamily="@font/montserrat_bold" android:text="#1" android:textColor="@color/info" android:textSize="44sp" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toBottomOf="@id/lbl_ranking" />
        <ImageView
            android:layout_width="40dp" android:layout_height="40dp" android:layout_marginStart="5dp" android:src="@drawable/icon_svg_bigstar" app:layout_constraintBottom_toBottomOf="@id/lbl_number1" app:layout_constraintStart_toEndOf="@id/lbl_number1" app:layout_constraintTop_toTopOf="@id/lbl_number1" app:tint="@color/yellow_65" />
        <TextView
            android:id="@+id/lbl_prod_top"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/roboto"
            android:text="PRODUCTO ESTRELLA TOP"
            android:textColor="@color/info"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lbl_number1" />
        <TextView
            android:id="@+id/tvLetraInicial"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="16dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/rectangular_badge_info"
            android:fontFamily="@font/roboto_medium"
            android:gravity="center"
            android:text="P"
            android:textColor="@color/info"
            android:textSize="12sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/tvProductoEstrellaNombre"
            app:layout_constraintBottom_toBottomOf="@id/tvProductoEstrellaCategoria"/>
        <TextView
            android:id="@+id/tvProductoEstrellaNombre"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/montserrat_bold"
            android:text="Ceviche de conchas negras"
            android:textColor="@color/text_85"
            android:textSize="18sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/tvLetraInicial"
            app:layout_constraintTop_toBottomOf="@id/lbl_prod_top" />
        <TextView
            android:id="@+id/tvProductoEstrellaCategoria"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:fontFamily="@font/roboto"
            android:text="Fuente"
            android:textColor="@color/text_85"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="@id/tvProductoEstrellaNombre"
            app:layout_constraintStart_toStartOf="@id/tvProductoEstrellaNombre"
            app:layout_constraintTop_toBottomOf="@id/tvProductoEstrellaNombre" />
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/background_info"
            android:orientation="horizontal"
            android:padding="10dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvProductoEstrellaCategoria"
            android:baselineAligned="false">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="horizontal">
                <TextView android:id="@+id/tvProductoEstrellaVentas" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="2dp" android:fontFamily="@font/montserrat_bold" android:text="10,000" android:textColor="@color/white" android:textSize="24sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/montserrat" android:text="VENTAS" android:textColor="@color/white" android:textSize="14sp" />
            </LinearLayout>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_gravity="center_vertical" android:gravity="center_vertical" android:orientation="horizontal">
                <ImageView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginEnd="4dp" android:src="@drawable/icon_svg_fillup" app:tint="@color/white" android:scaleType="fitCenter"/>
                <TextView android:id="@+id/tvProductoEstrellaPorcentaje" android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/roboto_medium" android:text="90,45%" android:textColor="@color/white" android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <View
        android:id="@+id/divider_vertical_otros"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="@drawable/border_left"
        app:layout_constraintBottom_toBottomOf="@id/card_producto_top"
        app:layout_constraintStart_toEndOf="@id/guide_prod_25"
        app:layout_constraintTop_toTopOf="@id/card_producto_top" />
    <TextView
        android:id="@+id/lbl_otros_productos"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="20dp"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="8dp"
        android:fontFamily="@font/roboto_medium"
        android:text="OTROS PRODUCTOS ESTRELLA TOP"
        android:textColor="@color/info"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/divider_vertical_otros"
        app:layout_constraintTop_toBottomOf="@id/lbl_top10" />
    <View
        android:id="@+id/divider_horizontal_otros"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/border_bottom"
        app:layout_constraintEnd_toEndOf="@id/lbl_otros_productos"
        app:layout_constraintStart_toStartOf="@id/lbl_otros_productos"
        app:layout_constraintTop_toBottomOf="@id/lbl_otros_productos" />
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollProductos"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        android:overScrollMode="never"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/lbl_otros_productos"
        app:layout_constraintStart_toStartOf="@id/lbl_otros_productos"
        app:layout_constraintTop_toBottomOf="@id/divider_horizontal_otros">
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/listaOtrosProductosEstrella"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:overScrollMode="never" />
    </androidx.core.widget.NestedScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>

